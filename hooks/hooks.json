{
  "description": "Auto-detect brand names in user prompts and inject design context",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject-context.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
